{
  "@context": {
    "@vocab": "https://schema.org/",
    "sendle": "https://api-evangelist.github.io/sendle/vocab#",
    "Order": "sendle:Order",
    "Parcel": "ParcelDelivery",
    "TrackingEvent": "sendle:TrackingEvent",
    "Manifest": "sendle:Manifest",
    "Product": "sendle:Product",
    "sendle_reference": { "@id": "sendle:sendleReference" },
    "tracking_url": { "@id": "trackingUrl", "@type": "@id" },
    "order_url": { "@id": "url", "@type": "@id" },
    "customer_reference": { "@id": "sendle:customerReference" },
    "weight": { "@id": "weight" },
    "dimensions": { "@id": "depth" },
    "sender": { "@id": "sender" },
    "receiver": { "@id": "deliveryAddress" },
    "address_line1": { "@id": "streetAddress" },
    "address_line2": { "@id": "sendle:addressLine2" },
    "suburb": { "@id": "addressLocality" },
    "state_name": { "@id": "addressRegion" },
    "postcode": { "@id": "postalCode" },
    "country": { "@id": "addressCountry" },
    "scan_time": { "@id": "dateRead", "@type": "http://www.w3.org/2001/XMLSchema#dateTime" },
    "event_type": { "@id": "sendle:eventType" },
    "delivered_on": { "@id": "expectedArrivalUntil", "@type": "http://www.w3.org/2001/XMLSchema#date" },
    "pickup_date": { "@id": "sendle:pickupDate", "@type": "http://www.w3.org/2001/XMLSchema#date" },
    "price": { "@id": "totalPaymentDue" },
    "amount": { "@id": "price" },
    "currency": { "@id": "priceCurrency" },
    "product_code": { "@id": "sendle:productCode" },
    "first_mile_option": { "@id": "sendle:firstMileOption" }
  }
}
